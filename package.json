{
  "name": "specflow-vscode",
  "displayName": "SpecFlow for VSCode",
  "description": "Spec-driven development workspace layer for VSCode",
  "version": "0.0.3",
  "publisher": "specflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BeSl/spec_flow_ui.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:specflow.hello",
    "onCommand:specflow.initializeProject",
    "onCommand:specflow.createSpecification",
    "onCommand:specflow.createChildSpecification",
    "onCommand:specflow.openDashboard",
    "onCommand:specflow.validateProject",
    "onCommand:specflow.refreshSpecs",
    "onCommand:specflow.openSpecFile",
    "onCommand:specflow.generatePrompt",
    "onCommand:specflow.openTaskBoard",
    "onCommand:specflow.openTaskSource",
    "onCommand:specflow.detectCompatibility",
    "onCommand:specflow.runReleaseQa",
    "onCommand:specflow.openProductMap",
    "onView:specflow.specTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specflow.hello",
        "title": "SDD: Hello SpecFlow"
      },
      {
        "command": "specflow.initializeProject",
        "title": "SDD: Initialize Project"
      },
      {
        "command": "specflow.createSpecification",
        "title": "SDD: Create Specification"
      },
      {
        "command": "specflow.createChildSpecification",
        "title": "SDD: Create Child Specification"
      },
      {
        "command": "specflow.openDashboard",
        "title": "SDD: Open Dashboard"
      },
      {
        "command": "specflow.validateProject",
        "title": "SDD: Validate Project"
      },
      {
        "command": "specflow.refreshSpecs",
        "title": "SDD: Refresh Specs"
      },
      {
        "command": "specflow.openSpecFile",
        "title": "SDD: Open Spec File"
      },
      {
        "command": "specflow.generatePrompt",
        "title": "SDD: Generate Prompt"
      },
      {
        "command": "specflow.openTaskBoard",
        "title": "SDD: Open Task Board"
      },
      {
        "command": "specflow.openTaskSource",
        "title": "SDD: Open Task Source"
      },
      {
        "command": "specflow.detectCompatibility",
        "title": "SDD: Detect Compatibility"
      },
      {
        "command": "specflow.runReleaseQa",
        "title": "SDD: Run Release QA"
      },
      {
        "command": "specflow.openProductMap",
        "title": "SDD: Open Product Map"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specflow",
          "title": "SpecFlow",
          "icon": "assets/specflow-activity.svg"
        }
      ]
    },
    "views": {
      "specflow": [
        {
          "id": "specflow.specTree",
          "name": "Specs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specflow.refreshSpecs",
          "when": "view == specflow.specTree",
          "group": "navigation"
        },
        {
          "command": "specflow.openProductMap",
          "when": "view == specflow.specTree",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "specflow.openDashboard",
          "when": "view == specflow.specTree && viewItem == specNode",
          "group": "inline"
        },
        {
          "command": "specflow.createChildSpecification",
          "when": "view == specflow.specTree && viewItem == specNode",
          "group": "inline@2"
        },
        {
          "command": "specflow.openSpecFile",
          "when": "view == specflow.specTree && viewItem == specNode",
          "group": "navigation"
        },
        {
          "command": "specflow.openTaskBoard",
          "when": "view == specflow.specTree && viewItem == specNode",
          "group": "navigation@2"
        },
        {
          "command": "specflow.openProductMap",
          "when": "view == specflow.specTree && viewItem == specNode",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.1",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.95.0",
    "eslint": "^9.14.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
